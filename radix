#include<stdio.h>

void radixSort(int a[],int n)
{
    int bucket[10][20],count[10];
    int i,j,k,pass,div=1,max=0;

    for(i=0;i<n;i++)
        if(a[i]>max)
            max=a[i];

    while(max>0)
    {
        pass++;
        max=max/10;
    }

    for(i=0;i<pass;i++)
    {
        for(j=0;j<10;j++)
            count[j]=0;

        for(j=0;j<n;j++)
        {
            k=(a[j]/div)%10;
            bucket[k][count[k]++]=a[j];
        }

        k=0;

        for(j=0;j<10;j++)
        {
            int p;
            for(p=0;p<count[j];p++)
                a[k++]=bucket[j][p];
        }

        div=div*10;
    }
}

int main()
{
    int n,i;

    printf("Enter number of elements: ");
    scanf("%d",&n);

    int a[n];

    printf("Enter elements: ");
    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    radixSort(a,n);

    printf("Sorted Array: ");
    for(i=0;i<n;i++)
        printf("%d ",a[i]);

    return 0;
}
