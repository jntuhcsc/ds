#include<stdio.h>

void shellSort(int a[],int n)
{
    int gap,i,j,temp;

    for(gap=n/2;gap>0;gap=gap/2)
    {
        for(i=gap;i<n;i++)
        {
            temp=a[i];

            for(j=i;j>=gap && a[j-gap]>temp;j-=gap)
                a[j]=a[j-gap];

            a[j]=temp;
        }
    }
}

int main()
{
    int n,i;

    printf("Enter number of elements: ");
    scanf("%d",&n);

    int a[n];

    printf("Enter elements: ");
    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    shellSort(a,n);

    printf("Sorted Array: ");
    for(i=0;i<n;i++)
        printf("%d ",a[i]);

    return 0;
}
